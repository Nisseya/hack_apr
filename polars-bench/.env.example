# ==== Database ====
DATABASE_URL=postgresql://postgres:postgres@db:5432/polars_bench

# ==== better-auth ====
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-strong-random-secret
BETTER_AUTH_URL=http://localhost:3000

# ==== OAuth providers ====
# GitHub: https://github.com/settings/developers → New OAuth App
#   Homepage URL:       http://localhost:3000
#   Callback URL:       http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
#   Authorized redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==== Benchmark backends (FastAPI) ====
# Fallback test backend (used only if a team has not set its own VM URL).
# The team's VM URL, set on the team page, takes precedence for 'test' submissions.
BACKEND_TEST_URL=http://host.docker.internal:8000

# Remote backend for the official 'global' run — POSTs to {URL}/submit_final
BACKEND_GLOBAL_URL=https://your-global-backend.example.com

# Secret expected by the global backend's /submit_final endpoint.
# Must match SUBMIT_FINAL_SECRET on the FastAPI side. Never exposed to the browser.
BACKEND_GLOBAL_SECRET=New_key
